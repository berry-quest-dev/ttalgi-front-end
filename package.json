{
  "packageManager": "pnpm@9.15.1",
  "name": "ttalgi-front-end",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "copy-favicon": "node copy-files.js",
    "reinstall": "rm -rf node_modules .turbo .next && pnpm install",
    "dev": "turbo dev",
    "dev:web": "pnpm --filter=web dev",
    "dev:admin": "pnpm --filter=admin dev",
    "build": "turbo build",
    "build:ui": "pnpm --filter @packages/ui build",
    "lint": "turbo run lint --cache-dir=.turbo",
    "format": "prettier --write .",
    "test": "turbo run test",
    "test:web": "pnpm --filter=web test",
    "test:admin": "pnpm --filter=admin test",
    "storybook": "pnpm --filter=storybook dev"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@storybook/react": "^7.6.20",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.3",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.4.17",
    "tiny-invariant": "^1.3.3",
    "ts-dedent": "^2.2.0",
    "ts-jest": "^29.2.6",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.74.4",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "next": "^15.3.1",
    "next-transpile-modules": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^4.4.1"
  }
}
